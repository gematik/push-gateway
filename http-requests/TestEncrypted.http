### 200 - Batch size exceeds maximum limit (100 notifications) (1 below threshold)

< {%
    const notifications = [];

    for (let i = 1; i <= 99; i++) {
        notifications.push({
            id: `enc_batch_${i}`,
            notification: {
                ciphertext: "{{examples.ciphertext_one}}",
                time_message_encrypted: "2023-10",
                key_identifier: "123e4567-e89b-12d3-a456-426614174000",
                prio: i % 2 === 0 ? "high" : "low",
                counts: {
                    unread: 2,
                    missed_calls: 0
                },
                device: {
                    app_id: "de.gematik.push-poc-ios.apns",
                    pushkey: "80c3b239e93b3cd35c5cb311f3597291d70c18e0d0539083b150440ad05bf4d7df3c2169060a12e2e1fcb051bc551d3f3698de1aa1cc079ff3788cf6b847d21a5347f2bf38919ce3b067cec92be53f75",
                    pushkey_ts: 1634025600,
                    data: {
                        format: "format"
                    },
                    tweaks: {
                        tweak: "tweak"
                    }
                }
            }
        });
    }

    request.variables.set("notifications", [notifications])
%}

POST {{baseUrl.api}}/push/v1/notifyEncrypted/batch
Content-Type: application/json
Accept: application/json

{
  "notifications": {{ notifications }}
}

> {%
    client.test("Status is 200", function() {
        client.assert(response.status === 200, "Expected 200");

### 200 - Two notifications one device

POST {{baseUrl.api}}/push/v1/notifyEncrypted/batch
Content-Type: application/json
Accept: application/json

{
  "notifications": [
    {
      "id": "enc_batch_1",
      "notification": {
        "ciphertext": "{{examples.ciphertext_one}}",
        "time_message_encrypted": "2023-10",
        "key_identifier": "123e4567-e89b-12d3-a456-426614174000",
        "prio": "high",
        "counts": {
          "unread": 1,
          "missed_calls": 0
        },
        "device": {
          "app_id": "{{apns.pushClients.one.appId}}",
          "pushkey": "{{apns.pushClients.one.pushKey}}",
          "pushkey_ts": 1634025600,
          "data": {
            "format": "format"
          },
          "tweaks": {
            "tweak": "tweak"
          }
        }
      }
    },
    {
      "id": "enc_batch_2",
      "notification": {
        "ciphertext": "{{examples.ciphertext_two}}",
        "time_message_encrypted": "2023-10",
        "key_identifier": "123e4567-e89b-12d3-a456-426614174000",
        "prio": "low",
        "counts": {
          "unread": 2,
          "missed_calls": 0
        },
        "device": {
          "app_id": "{{apns.pushClients.one.appId}}",
          "pushkey": "{{apns.pushClients.one.pushKey}}",
          "pushkey_ts": 1634025600,
          "data": {
            "format": "format"
          },
          "tweaks": {
            "tweak": "tweak"
          }
        }
      }
    }
  ]
}

> {%
    client.test("Status is 200", function() {
        client.assert(response.status === 200, "Expected 200");
    });
%}


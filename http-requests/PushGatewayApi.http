### Push plain data to the gateway
## Push plain data to the gateway
POST {{baseUrl.api}}/push/v1/notify
Content-Type: application/json
Accept: application/json

{
  "notification": {
      "event_id": "event_id",
      "room_id": "room_id",
      "type": "type",
      "sender": "sender",
      "sender_display_name": "sender_display_name",
      "room_name": "room_name",
      "room_alias": "room_alias",
      "user_is_target": true,
      "prio": "high",
      "content": {
        "content": "content"
      },
      "counts": {
        "unread": 1,
        "missed_calls": 0
      },
      "devices": [
        {
          "app_id": "{{apns.pushClients.one.appId}}",
          "pushkey": "{{apns.pushClients.one.pushKey}}"
        },
        {
          "app_id": "{{apns.pushClients.two.appId}}",
          "pushkey": "{{apns.pushClients.two.pushKey}}"
        },
        {
          "app_id": "{{apns.pushClients.noClient.appId}}",
          "pushkey": "{{apns.pushClients.noClient.pushKey}}"
        },
        {
          "app_id": "{{apns.pushClients.noProvider.appId}}",
          "pushkey": "{{apns.pushClients.noProvider.pushKey}}"
        },
        {
          "app_id": "{{apns.pushClients.rejected.appId}}",
          "pushkey": "{{apns.pushClients.rejected.pushKey}}"
        },
        {
          "app_id": "{{firebase.pushClients.one.appId}}",
          "pushkey": "{{firebase.pushClients.one.pushKey}}"
        },
        {
          "app_id": "{{firebase.pushClients.noClient.appId}}",
          "pushkey": "{{firebase.pushClients.noClient.pushKey}}"
        },
        {
          "app_id": "{{firebase.pushClients.noProvider.appId}}",
          "pushkey": "{{firebase.pushClients.noProvider.pushKey}}"
        },
        {
          "app_id": "{{firebase.pushClients.rejected.appId}}",
          "pushkey": "{{firebase.pushClients.rejected.pushKey}}"
        }
      ]
    }
}
